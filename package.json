{
  "name": "elodie-duhayon-site",
  "version": "1.0.0",
  "private": true,
  "description": "Site personal trainer Élodie Duhayon — Next.js + Prisma + MySQL",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "_comment_prod": "— Scripts PROD (MySQL, schema.prisma) —",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "_comment_dev": "— Scripts DEV local (SQLite, schema.dev.prisma) —",
    "dev:prisma:generate": "prisma generate --schema=prisma/schema.dev.prisma",
    "dev:prisma:push": "prisma db push --schema=prisma/schema.dev.prisma",
    "dev:prisma:studio": "prisma studio --schema=prisma/schema.dev.prisma",
    "dev:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/extension-image": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "14.2.15",
    "next-auth": "^4.24.10",
    "nodemailer": "^7.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "slugify": "^1.6.6",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
