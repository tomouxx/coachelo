# ============== Base de données MySQL Infomaniak ==============
# Format : mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Sur Infomaniak : manager.infomaniak.com → Hébergement → Bases de données
DATABASE_URL="mysql://user:password@mysql.infomaniak.com:3306/elodie_duhayon"

# ============== NextAuth ==============
# Générer la secret avec :  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-avec-une-chaine-aleatoire"
NEXTAUTH_URL="https://www.coachelo.ch"

# ============== Comptes admin initiaux (utilisé par seed.ts) ==============
ADMIN_EMAIL_ELODIE="elodie@coachelo.ch"
ADMIN_PASSWORD_ELODIE="a-changer-au-premier-login"
ADMIN_EMAIL_THOMAS="thomas@coachelo.ch"
ADMIN_PASSWORD_THOMAS="a-changer-au-premier-login"

# ============== SMTP Infomaniak ==============
# Docs : https://www.infomaniak.com/fr/support/faq/1941
SMTP_HOST="mail.infomaniak.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="contact@coachelo.ch"
SMTP_PASSWORD="mot-de-passe-email-infomaniak"
